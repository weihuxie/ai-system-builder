# ───────────────────────────────────────────
# Server-side secrets (Cloud Run env, NOT exposed to client)
# ───────────────────────────────────────────

# LLM providers (any subset — the DB-driven chain in /admin decides fallback order)
# Gemini is also used for STT.
GEMINI_API_KEY=
KIMI_API_KEY=
DEEPSEEK_API_KEY=

# Supabase (service role for server writes)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=

# Admin auth
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=
JWT_SECRET=change-me-to-a-32-char-random-string

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Server runtime
PORT=8080
NODE_ENV=development

# ───────────────────────────────────────────
# Client-side (must be prefixed VITE_)
# Safe to be in bundle
# ───────────────────────────────────────────
VITE_API_BASE=/api
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=
