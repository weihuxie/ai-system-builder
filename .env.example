# ───────────────────────────────────────────
# Server-side secrets (Cloud Run env, NOT exposed to client)
# ───────────────────────────────────────────

# LLM providers (any subset — the DB-driven chain in /admin decides fallback order)
# Gemini is also used for STT.
GEMINI_API_KEY=
KIMI_API_KEY=
DEEPSEEK_API_KEY=

# Supabase (service role for server writes)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=

# Admin auth
# Supabase JWT signing secret — copy from Supabase Dashboard →
# Project Settings → API → "JWT Secret". The server verifies the bearer
# token from the client against this; no network hop per request.
SUPABASE_JWT_SECRET=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Server runtime
PORT=8080
NODE_ENV=development

# Public URL of the deployed frontend. Used by invite emails for the
# magic-link redirect (redirectTo=${APP_URL}/admin). Leave UNSET in local
# dev / tests to skip sending real emails — whitelist-only invite still
# works, super_admin just has to notify the invitee manually.
# Example: https://ai-system-builder.vercel.app
APP_URL=

# ───────────────────────────────────────────
# Client-side (must be prefixed VITE_)
# Safe to be in bundle
# ───────────────────────────────────────────
VITE_API_BASE=/api
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=
