# ───────────────────────────────────────────
# Test environment — separate Supabase project (free tier) from prod.
# Copy to .env.test, fill from Supabase Dashboard → Project Settings → API.
# DO NOT point this at the production SUPABASE_URL; tests truncate tables.
# ───────────────────────────────────────────

# The test Supabase project (must be DIFFERENT from SUPABASE_URL in .env)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=

# Server runtime
NODE_ENV=test
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Client bundle (Playwright picks these up via vite's env injection)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE=/api

# LLM keys are NOT required for tests (routes that need them are mocked
# at the provider-layer). Leave blank.
GEMINI_API_KEY=
KIMI_API_KEY=
DEEPSEEK_API_KEY=
