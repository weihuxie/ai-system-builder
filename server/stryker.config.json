{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing baseline. Scope intentionally narrow on first run — only modules with strong offline unit-test coverage. Expanding scope to integration-tested modules (routes/*) requires a separate stryker.integration.config.json with .env.test loaded.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.unit.config.ts"
  },
  "mutate": [
    "src/middleware/errors.ts",
    "src/lib/generateCache.ts",
    "src/lib/prompt.ts",
    "src/lib/providers.ts"
  ],
  "checkers": [],
  "reporters": ["progress", "html", "json", "clear-text"],
  "htmlReporter": { "fileName": "stryker-report/index.html" },
  "jsonReporter": { "fileName": "stryker-report/mutation.json" },
  "coverageAnalysis": "all",
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 0
  },
  "tempDirName": ".stryker-tmp",
  "concurrency": 2,
  "timeoutMS": 30000
}
